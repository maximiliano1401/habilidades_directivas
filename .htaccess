# Configuración de Apache para el sistema de Habilidades Directivas

# Establecer página de inicio
DirectoryIndex index.php

# Prevenir listado de directorios
Options -Indexes

# Configuración de encoding
AddDefaultCharset UTF-8

# Proteger archivos sensibles
<FilesMatch "\.(sql|json|md|lock)$">
    Require all denied
</FilesMatch>

<Files ".gitkeep">
    Require all denied
</Files>

<Files ".gitignore">
    Require all denied
</Files>

# Proteger directorios sensibles
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^config/ - [F,L]
    RewriteRule ^database/ - [F,L]
    RewriteRule ^storage/uploads/.*\.(png|jpg|jpeg|svg|webp)$ - [L]
    RewriteRule ^storage/ - [F,L]
    RewriteRule ^vendor/ - [F,L]
    RewriteRule ^docs/ - [F,L]
</IfModule>

# Proteger directorio data
RedirectMatch 403 ^/habilidades_directivas/data/.*$

# Configuración de seguridad
<IfModule mod_headers.c>
    # Prevenir XSS
    Header set X-XSS-Protection "1; mode=block"
    
    # Prevenir clickjacking
    Header always append X-Frame-Options SAMEORIGIN
    
    # Configurar Content-Type
    Header set X-Content-Type-Options nosniff
</IfModule>
